{
  "dependencies": {
    "concurrently": "^9.1.0",
    "serve": "^14.2.4"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.16"
  },
  "scripts": {
    "build:css": "npx tailwindcss -i src/styles/input.css -o dist/assets/styles/tailwind.css",
    "build": "dx build --release",
    "serve": "serve dist",
    "dev": "concurrently \"npm run build:css --watch\" \"dx serve\""
  }
}
